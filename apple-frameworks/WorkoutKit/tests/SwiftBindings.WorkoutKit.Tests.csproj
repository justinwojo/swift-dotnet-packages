<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0-ios;net10.0-macos;net10.0-maccatalyst</TargetFrameworks>
    <RuntimeIdentifier Condition="'$(TargetFramework)' == 'net10.0-ios' and '$(RuntimeIdentifier)' == ''">iossimulator-arm64</RuntimeIdentifier>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.workoutkit.tests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-ios'))">17.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-macos'))">14.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-maccatalyst'))">17.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative Condition="$(TargetFramework.Contains('-ios'))">true</IncludeSwiftBindingsRuntimeNative>
    <!-- macOS console apps don't need provisioning -->
    <CodesignProvision Condition="$(TargetFramework.Contains('-macos'))"></CodesignProvision>
  </PropertyGroup>

  <!-- iOS and MacCatalyst are UIKit app targets — they need an Info.plist.
       macOS (console) does not. -->
  <ItemGroup Condition="$(TargetFramework.Contains('-ios')) or $(TargetFramework.Contains('-maccatalyst'))">
    <None Include="Info.plist" />
  </ItemGroup>

  <!-- ProjectReference, not PackageReference — a PR changing the sibling csproj
       must be validated against the local change, not a nuget.org version. -->
  <ItemGroup>
    <ProjectReference Include="../SwiftBindings.WorkoutKit.csproj" />
  </ItemGroup>

</Project>
