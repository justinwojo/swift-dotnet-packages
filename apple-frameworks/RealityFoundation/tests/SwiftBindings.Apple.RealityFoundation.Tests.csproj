<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-ios</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.realityfoundation.tests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>17.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative>true</IncludeSwiftBindingsRuntimeNative>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Info.plist" />
  </ItemGroup>

  <!-- ProjectReference, not PackageReference — a PR changing the sibling csproj
       must be validated against the local change, not a nuget.org version. -->
  <ItemGroup>
    <ProjectReference Include="../SwiftBindings.Apple.RealityFoundation.csproj" />
  </ItemGroup>

</Project>
