<Project Sdk="SwiftBindings.Sdk/0.15.0">
  <PropertyGroup>
    <!-- Override single-TFM default from Directory.Build.props -->
    <TargetFramework />
    <TargetFrameworks>net10.0-ios26.2;net10.0-macos26.2;net10.0-maccatalyst26.2;net10.0-tvos26.2</TargetFrameworks>
    <PackageId>SwiftBindings.Apple.TipKit</PackageId>
    <Version>26.2.7</Version>
    <Description>Native Swift interop bindings for Apple TipKit</Description>
    <PackageTags>$(CommonPackageTags);macos;tvos;maccatalyst;tipkit;tips;onboarding</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <SwiftAppleFrameworkTarget Include="TipKit" />
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
