<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-ios</TargetFramework>
    <!-- Keep the produced app bundle name aligned with the Nuke harness's
         ResolveTestNames convention ("SwiftBindings.{library}.Tests"), which
         hasn't yet been updated for the apple-frameworks csproj rename. -->
    <AssemblyName>SwiftBindings.RealityKit.Tests</AssemblyName>
    <RootNamespace>SwiftBindings.RealityKit.Tests</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.realitykit.tests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>17.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative>true</IncludeSwiftBindingsRuntimeNative>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Info.plist" />
  </ItemGroup>

  <!-- ProjectReference, not PackageReference — a PR changing the sibling csproj
       must be validated against the local change, not a nuget.org version.
       RealityKit also references the sibling RealityFoundation library directly
       so the cross-module re-export edge is exercised by ProjectReference too. -->
  <ItemGroup>
    <ProjectReference Include="../SwiftBindings.Apple.RealityKit.csproj" />
    <ProjectReference Include="../../RealityFoundation/SwiftBindings.Apple.RealityFoundation.csproj" />
  </ItemGroup>

</Project>
