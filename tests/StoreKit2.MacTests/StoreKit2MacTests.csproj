<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-macos26.2</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <SupportedOSPlatformVersion>12.0</SupportedOSPlatformVersion>
    <ApplicationId>com.swiftbindings.storekit2mactests</ApplicationId>
    <!-- Override codesign from tests/Directory.Build.props.local — macOS console apps
         don't need the same provisioning as iOS apps -->
    <CodesignProvision></CodesignProvision>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SwiftBindings.StoreKit2" Version="26.2.0" />
  </ItemGroup>

</Project>
