<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-ios</TargetFramework>
    <RuntimeIdentifier>iossimulator-arm64</RuntimeIdentifier>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.stripesimtests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative>false</IncludeSwiftBindingsRuntimeNative>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Info.plist" />
  </ItemGroup>

  <!-- Reference library projects — brings in bindings and Swift.Runtime transitively -->
  <ItemGroup>
    <ProjectReference Include="../../libraries/Stripe/StripeCore/Swift.StripeCore.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripePayments/Swift.StripePayments.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripePaymentSheet/Swift.StripePaymentSheet.csproj" />
  </ItemGroup>

  <!-- Native frameworks must be referenced directly (NativeReference doesn't propagate through ProjectReference) -->
  <ItemGroup>
    <NativeReference Include="../../libraries/Stripe/StripeCore/StripeCore.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeCore/obj/Debug/net10.0-ios/swift-binding/StripeCoreSwiftBindings.xcframework"
                     Condition="Exists('../../libraries/Stripe/StripeCore/obj/Debug/net10.0-ios/swift-binding/StripeCoreSwiftBindings.xcframework')">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePayments/StripePayments.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePayments/obj/Debug/net10.0-ios/swift-binding/StripePaymentsSwiftBindings.xcframework"
                     Condition="Exists('../../libraries/Stripe/StripePayments/obj/Debug/net10.0-ios/swift-binding/StripePaymentsSwiftBindings.xcframework')">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePaymentSheet/StripePaymentSheet.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePaymentSheet/obj/Debug/net10.0-ios/swift-binding/StripePaymentSheetSwiftBindings.xcframework"
                     Condition="Exists('../../libraries/Stripe/StripePaymentSheet/obj/Debug/net10.0-ios/swift-binding/StripePaymentSheetSwiftBindings.xcframework')">
      <Kind>Framework</Kind>
    </NativeReference>
  </ItemGroup>

</Project>
