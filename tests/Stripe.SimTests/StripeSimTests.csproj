<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-ios</TargetFramework>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">iossimulator-arm64</RuntimeIdentifier>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.stripesimtests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative>true</IncludeSwiftBindingsRuntimeNative>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Info.plist" />
  </ItemGroup>

  <!-- Reference library projects — brings in bindings and SwiftBindings.Runtime transitively -->
  <ItemGroup>
    <ProjectReference Include="../../libraries/Stripe/Stripe/SwiftBindings.Stripe.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripePayments/SwiftBindings.Stripe.Payments.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripePaymentSheet/SwiftBindings.Stripe.PaymentSheet.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeCore/SwiftBindings.Stripe.Core.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeUICore/SwiftBindings.Stripe.UICore.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripePaymentsUI/SwiftBindings.Stripe.PaymentsUI.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeApplePay/SwiftBindings.Stripe.ApplePay.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeIdentity/SwiftBindings.Stripe.Identity.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeIssuing/SwiftBindings.Stripe.Issuing.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeCardScan/SwiftBindings.Stripe.CardScan.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeFinancialConnections/SwiftBindings.Stripe.FinancialConnections.csproj" />
    <ProjectReference Include="../../libraries/Stripe/StripeConnect/SwiftBindings.Stripe.Connect.csproj" />
  </ItemGroup>

  <!-- Native frameworks must be referenced directly (NativeReference doesn't propagate through ProjectReference) -->
  <ItemGroup>
    <NativeReference Include="../../libraries/Stripe/Stripe/Stripe.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePayments/StripePayments.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePaymentSheet/StripePaymentSheet.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeCore/StripeCore.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeUICore/StripeUICore.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripePaymentsUI/StripePaymentsUI.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeApplePay/StripeApplePay.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeIdentity/StripeIdentity.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeIssuing/StripeIssuing.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeCardScan/StripeCardScan.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeFinancialConnections/StripeFinancialConnections.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeConnect/StripeConnect.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/Stripe3DS2/Stripe3DS2.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
    <NativeReference Include="../../libraries/Stripe/StripeCameraCore/StripeCameraCore.xcframework">
      <Kind>Framework</Kind>
    </NativeReference>
  </ItemGroup>

  <!-- Wrapper xcframework: must be in a Target (not static ItemGroup) so the Exists() check
       runs AFTER the library project builds. Static ItemGroups evaluate before any build targets,
       so on a clean build the wrapper doesn't exist yet and gets silently omitted. -->
  <Target Name="_AddSwiftWrapperReference"
          BeforeTargets="ResolveNativeReferences"
          DependsOnTargets="ResolveProjectReferences">
    <ItemGroup>
      <NativeReference Include="../../libraries/Stripe/Stripe/obj/$(Configuration)/net10.0-ios/swift-binding/StripeSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/Stripe/obj/$(Configuration)/net10.0-ios/swift-binding/StripeSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripePayments/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentsSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripePayments/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentsSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripePaymentSheet/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentSheetSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripePaymentSheet/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentSheetSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeCore/obj/$(Configuration)/net10.0-ios/swift-binding/StripeCoreSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeCore/obj/$(Configuration)/net10.0-ios/swift-binding/StripeCoreSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeUICore/obj/$(Configuration)/net10.0-ios/swift-binding/StripeUICoreSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeUICore/obj/$(Configuration)/net10.0-ios/swift-binding/StripeUICoreSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripePaymentsUI/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentsUISwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripePaymentsUI/obj/$(Configuration)/net10.0-ios/swift-binding/StripePaymentsUISwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeApplePay/obj/$(Configuration)/net10.0-ios/swift-binding/StripeApplePaySwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeApplePay/obj/$(Configuration)/net10.0-ios/swift-binding/StripeApplePaySwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeIdentity/obj/$(Configuration)/net10.0-ios/swift-binding/StripeIdentitySwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeIdentity/obj/$(Configuration)/net10.0-ios/swift-binding/StripeIdentitySwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeIssuing/obj/$(Configuration)/net10.0-ios/swift-binding/StripeIssuingSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeIssuing/obj/$(Configuration)/net10.0-ios/swift-binding/StripeIssuingSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeCardScan/obj/$(Configuration)/net10.0-ios/swift-binding/StripeCardScanSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeCardScan/obj/$(Configuration)/net10.0-ios/swift-binding/StripeCardScanSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeFinancialConnections/obj/$(Configuration)/net10.0-ios/swift-binding/StripeFinancialConnectionsSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeFinancialConnections/obj/$(Configuration)/net10.0-ios/swift-binding/StripeFinancialConnectionsSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
      <NativeReference Include="../../libraries/Stripe/StripeConnect/obj/$(Configuration)/net10.0-ios/swift-binding/StripeConnectSwiftBindings.xcframework"
                       Condition="Exists('../../libraries/Stripe/StripeConnect/obj/$(Configuration)/net10.0-ios/swift-binding/StripeConnectSwiftBindings.xcframework')">
        <Kind>Framework</Kind>
      </NativeReference>
    </ItemGroup>
  </Target>

</Project>
