# Build outputs
bin/
obj/
*.nupkg
*.snupkg

# Test app build output
tests/*/bin/
tests/*/obj/

# Local codesigning override (developer-specific cert/team values)
tests/Directory.Build.props.local
Directory.Build.tests.props.local

# Nuke build harness output
build/bin/
build/obj/
.nuke/temp/

# Claude Code local state
.claude/

# Local NuGet packages
local-packages/

# xcframework build artifacts
**/xcframework-build/
**/.build-workspace/
**/DerivedData/
**/*.xcframework/

# Cached tool binaries (e.g. spm-to-xcframework — pinned + sha256-verified)
.tools/

# Generator output
**/output/
**/test-output/

# .NET
*.user
*.suo
*.vs/
*.DotSettings.user

# Secrets / credentials
.env*
*.key
*.pem

# macOS
.DS_Store

# IDE
.idea/
*.swp
*~
