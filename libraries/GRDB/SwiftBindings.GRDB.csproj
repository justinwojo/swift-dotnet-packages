<Project Sdk="SwiftBindings.Sdk/0.5.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.GRDB</PackageId>
    <Version>1.0.0</Version>
    <Description>Native Swift interop bindings for the GRDB SQLite toolkit</Description>
    <PackageTags>swift;dotnet;interop;grdb;sqlite;database;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
