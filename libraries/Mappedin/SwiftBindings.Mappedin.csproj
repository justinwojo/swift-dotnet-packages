<Project Sdk="SwiftBindings.Sdk/0.7.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Mappedin</PackageId>
    <Version>1.0.0</Version>
    <Description>Native Swift interop bindings for the Mappedin indoor mapping library</Description>
    <PackageTags>swift;dotnet;interop;mappedin;indoor-mapping;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
