<Project Sdk="SwiftBindings.Sdk/0.2.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SwiftWrapperRequired>false</SwiftWrapperRequired>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.BlinkIDUX</PackageId>
    <Version>7.6.2</Version>
    <Description>.NET bindings for the BlinkIDUX Swift library</Description>
    <PackageTags>swift;dotnet;interop;blinkidux;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <!-- BlinkIDUX depends on BlinkID — ProjectReference becomes PackageReference in NuGet -->
  <ItemGroup>
    <ProjectReference Include="../BlinkID/SwiftBindings.BlinkID.csproj" />
  </ItemGroup>

  <!-- BlinkID xcframework needed during binding generation -->
  <ItemGroup>
    <SwiftFrameworkDependency Include="../BlinkID/BlinkID.xcframework" />
  </ItemGroup>

</Project>
