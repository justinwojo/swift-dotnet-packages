<Project Sdk="SwiftBindings.Sdk/0.12.1">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SwiftWrapperRequired>false</SwiftWrapperRequired>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.BlinkIDUX</PackageId>
    <Version>7.8.0</Version>
    <Description>.NET bindings for the BlinkIDUX Swift library</Description>
    <PackageTags>$(CommonPackageTags);blinkid;blinkidux;id-scanning;ocr;ui</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <!-- BlinkIDUX depends on BlinkID. dotnet pack auto-emits the nuspec
       <dependency> from this ProjectReference (the target is a packable
       csproj with PackageId+Version), so no explicit PackageReference
       is needed — adding one would duplicate the nuspec entry. -->
  <ItemGroup>
    <ProjectReference Include="../BlinkID/SwiftBindings.BlinkID.csproj" />
  </ItemGroup>

  <!-- BlinkID xcframework needed during binding generation. PackageId +
       PackageVersion satisfy the SDK's pack-time SFD validation (SWIFTBIND040);
       they describe the NuGet package consumers will need to install at runtime,
       which is the sibling BlinkID package shipped from this repo. Microblink
       ships BlinkID and BlinkIDUX in lockstep, so the version tracks BlinkIDUX's. -->
  <ItemGroup>
    <SwiftFrameworkDependency Include="../BlinkID/BlinkID.xcframework"
                              PackageId="SwiftBindings.BlinkID"
                              PackageVersion="7.8.0" />
  </ItemGroup>

</Project>
