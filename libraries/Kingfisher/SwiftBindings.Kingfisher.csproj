<Project Sdk="SwiftBindings.Sdk/0.15.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Kingfisher</PackageId>
    <Version>1.0.0</Version>
    <Description>Native Swift interop bindings for the Kingfisher image downloading and caching library</Description>
    <PackageTags>$(CommonPackageTags);kingfisher;image;image-cache;download</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
