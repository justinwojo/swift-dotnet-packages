<Project Sdk="SwiftBindings.Sdk/0.4.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SwiftWrapperRequired>false</SwiftWrapperRequired>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Stripe.UICore</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the StripeUICore Swift library (internal Stripe dependency)</Description>
    <PackageTags>swift;dotnet;interop;stripeuicore;ios</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../StripeCore/SwiftBindings.Stripe.Core.csproj" />
  </ItemGroup>

</Project>
