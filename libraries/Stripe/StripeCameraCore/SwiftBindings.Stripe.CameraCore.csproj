<Project Sdk="SwiftBindings.Sdk/0.12.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Stripe.CameraCore</PackageId>
    <Version>25.15.0</Version>
    <Description>Transitive support package for SwiftBindings.Stripe.* — pulled in automatically by sibling Stripe packages that need camera-based scanning support (StripeCardScan, StripeIdentity). Not an entry point; do not install directly. Wraps Stripe's StripeCameraCore.xcframework.</Description>
    <PackageTags>$(CommonPackageTags);stripe;stripecameracore;payments</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" PackageId="SwiftBindings.Stripe.Core" PackageVersion="25.15.0" />
  </ItemGroup>

</Project>
