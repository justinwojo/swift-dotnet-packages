<Project Sdk="SwiftBindings.Sdk/0.6.1">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SwiftWrapperRequired>false</SwiftWrapperRequired>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Stripe</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the Stripe Swift library</Description>
    <PackageTags>swift;dotnet;interop;stripe;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" PackageId="SwiftBindings.Stripe.Core" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../StripeApplePay/StripeApplePay.xcframework" PackageId="SwiftBindings.Stripe.ApplePay" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../StripePayments/StripePayments.xcframework" PackageId="SwiftBindings.Stripe.Payments" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../StripePaymentsUI/StripePaymentsUI.xcframework" PackageId="SwiftBindings.Stripe.PaymentsUI" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../StripeUICore/StripeUICore.xcframework" PackageId="SwiftBindings.Stripe.UICore" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../StripeIssuing/StripeIssuing.xcframework" PackageId="SwiftBindings.Stripe.Issuing" PackageVersion="25.6.2" />
    <SwiftFrameworkDependency Include="../Stripe3DS2/Stripe3DS2.xcframework" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../StripeCore/SwiftBindings.Stripe.Core.csproj" />
    <ProjectReference Include="../StripeApplePay/SwiftBindings.Stripe.ApplePay.csproj" />
    <ProjectReference Include="../StripePayments/SwiftBindings.Stripe.Payments.csproj" />
  </ItemGroup>

</Project>
