<Project Sdk="Swift.Bindings.Sdk/0.1.0-preview.2">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.Stripe</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the Stripe Swift library</Description>
    <PackageTags>swift;dotnet;interop;stripe;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

<!-- BEGIN auto-detected SwiftFrameworkDependency -->
  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeApplePay/StripeApplePay.xcframework" />
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" />
    <SwiftFrameworkDependency Include="../StripeIssuing/StripeIssuing.xcframework" />
    <SwiftFrameworkDependency Include="../StripePayments/StripePayments.xcframework" />
    <SwiftFrameworkDependency Include="../StripePaymentsUI/StripePaymentsUI.xcframework" />
  </ItemGroup>
  <!-- END auto-detected SwiftFrameworkDependency -->

</Project>
