<Project Sdk="SwiftBindings.Sdk/0.1.1">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.Stripe</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the Stripe Swift library</Description>
    <PackageTags>swift;dotnet;interop;stripe;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

<!-- Auto-detection enabled: SwiftFrameworkDependency items auto-discovered via otool -L -->

  <ItemGroup>
    <ProjectReference Include="../StripeCore/Swift.StripeCore.csproj" />
    <ProjectReference Include="../StripeApplePay/Swift.StripeApplePay.csproj" />
    <ProjectReference Include="../StripePayments/Swift.StripePayments.csproj" />
  </ItemGroup>

</Project>
