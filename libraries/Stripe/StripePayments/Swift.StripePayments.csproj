<Project Sdk="SwiftBindings.Sdk/0.1.1">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.StripePayments</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the StripePayments Swift library</Description>
    <PackageTags>swift;dotnet;interop;stripepayments;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

<!-- BEGIN auto-detected SwiftFrameworkDependency -->
  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" />
  </ItemGroup>
  <!-- END auto-detected SwiftFrameworkDependency -->

  <ItemGroup>
    <ProjectReference Include="../StripeCore/Swift.StripeCore.csproj" />
  </ItemGroup>

</Project>
