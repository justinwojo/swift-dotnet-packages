<Project Sdk="SwiftBindings.Sdk/0.15.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SwiftFrameworkType>ObjC</SwiftFrameworkType>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Stripe.ThreeDS2</PackageId>
    <Version>25.15.0</Version>
    <Description>Transitive support package for SwiftBindings.Stripe.* — pulled in automatically by sibling Stripe packages that need 3-D Secure 2 support. Not an entry point; do not install directly. Wraps Stripe's ObjC-only Stripe3DS2.xcframework.</Description>
    <PackageTags>$(CommonPackageTags);stripe;stripe3ds2;payments;3ds</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
