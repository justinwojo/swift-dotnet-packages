<Project Sdk="SwiftBindings.Sdk/0.16.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Stripe.Core</PackageId>
    <Version>25.15.0</Version>
    <Description>.NET bindings for the StripeCore Swift library</Description>
    <PackageTags>$(CommonPackageTags);stripe;stripecore;payments</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
