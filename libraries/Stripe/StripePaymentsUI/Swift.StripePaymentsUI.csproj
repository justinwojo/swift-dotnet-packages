<Project Sdk="Swift.Bindings.Sdk/0.1.0-preview.16">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.StripePaymentsUI</PackageId>
    <Version>25.6.2</Version>
    <Description>.NET bindings for the StripePaymentsUI Swift library</Description>
    <PackageTags>swift;dotnet;interop;stripepaymentsui;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

<!-- BEGIN auto-detected SwiftFrameworkDependency -->
  <ItemGroup>
    <SwiftFrameworkDependency Include="../StripeCore/StripeCore.xcframework" />
    <SwiftFrameworkDependency Include="../StripePayments/StripePayments.xcframework" />
    <SwiftFrameworkDependency Include="../StripeUICore/StripeUICore.xcframework" />
  </ItemGroup>
  <!-- END auto-detected SwiftFrameworkDependency -->

  <ItemGroup>
    <ProjectReference Include="../StripeCore/Swift.StripeCore.csproj" />
    <ProjectReference Include="../StripePayments/Swift.StripePayments.csproj" />
    <ProjectReference Include="../StripeUICore/Swift.StripeUICore.csproj" />
  </ItemGroup>

</Project>
