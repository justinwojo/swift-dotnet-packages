    <SwiftFrameworkDependency Include="../StripeUICore/StripeUICore.xcframework" PackageId="SwiftBindings.Stripe.UICore" PackageVersion="25.15.0" />
  </ItemGroup>
  <!-- END auto-detected SwiftFrameworkDependency -->

