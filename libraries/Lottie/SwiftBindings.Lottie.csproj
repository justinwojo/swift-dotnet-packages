<Project Sdk="SwiftBindings.Sdk/0.15.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Lottie</PackageId>
    <Version>4.6.2</Version>
    <Description>.NET bindings for the Lottie Swift library</Description>
    <PackageTags>$(CommonPackageTags);lottie;animation;vector-animation</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
