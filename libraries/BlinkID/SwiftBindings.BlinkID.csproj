<Project Sdk="SwiftBindings.Sdk/0.2.0">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.BlinkID</PackageId>
    <Version>7.6.2</Version>
    <Description>.NET bindings for the BlinkID Swift library</Description>
    <PackageTags>swift;dotnet;interop;blinkid;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
