<Project Sdk="SwiftBindings.Sdk/0.12.1">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <!-- Closed-source framework: wrapper compilation fails due to internal types -->
    <SwiftWrapperRequired>false</SwiftWrapperRequired>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.BlinkID</PackageId>
    <Version>7.8.0</Version>
    <Description>.NET bindings for the BlinkID Swift library</Description>
    <PackageTags>$(CommonPackageTags);blinkid;id-scanning;ocr;document-scanning</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
