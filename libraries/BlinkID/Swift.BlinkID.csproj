<Project Sdk="Swift.Bindings.Sdk/0.1.0-preview.7">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.BlinkID</PackageId>
    <Version>7.6.2</Version>
    <Description>.NET bindings for the BlinkID Swift library</Description>
    <PackageTags>swift;dotnet;interop;blinkid;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
