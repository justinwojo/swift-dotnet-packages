<Project Sdk="SwiftBindings.Sdk/0.11.0">

  <PropertyGroup>
    <!-- Override single-TFM default from Directory.Build.props -->
    <TargetFramework />
    <TargetFrameworks>net10.0-ios;net10.0-macos;net10.0-tvos</TargetFrameworks>

    <!-- NuGet package metadata -->
    <PackageId>SwiftBindings.Nuke</PackageId>
    <Version>13.0.6</Version>
    <Description>.NET bindings for the Nuke Swift image loading library</Description>
    <PackageTags>swift;dotnet;interop;nuke;image-loading;ios;macos;tvos</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
