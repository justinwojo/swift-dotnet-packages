<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework />
    <TargetFrameworks>net10.0-ios;net10.0-macos;net10.0-tvos</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationId>com.swiftbindings.nuke.tests</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-ios'))">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-macos'))">12.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$(TargetFramework.Contains('-tvos'))">15.0</SupportedOSPlatformVersion>
    <IncludeSwiftBindingsRuntimeNative Condition="$(TargetFramework.Contains('-ios')) or $(TargetFramework.Contains('-tvos'))">true</IncludeSwiftBindingsRuntimeNative>
    <!-- macOS console apps don't need provisioning -->
    <CodesignProvision Condition="$(TargetFramework.Contains('-macos'))"></CodesignProvision>
  </PropertyGroup>

  <!-- iOS and tvOS are UIKit app targets — they need an Info.plist + bundled image.
       macOS (console) does not. -->
  <ItemGroup Condition="$(TargetFramework.Contains('-ios')) or $(TargetFramework.Contains('-tvos'))">
    <None Include="Info.plist" />
    <BundleResource Include="Resources/test_image.png" />
  </ItemGroup>

  <!-- Reference the library project — NativeReference items (source + wrapper xcframeworks)
       propagate automatically via the SDK's GetNativeManifest target. -->
  <ItemGroup>
    <ProjectReference Include="../SwiftBindings.Nuke.csproj" />
  </ItemGroup>

</Project>
