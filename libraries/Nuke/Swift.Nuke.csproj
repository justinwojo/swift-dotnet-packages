<Project Sdk="Swift.Bindings.Sdk/0.1.0-preview.7">

  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>

    <!-- NuGet package metadata -->
    <PackageId>Swift.Nuke</PackageId>
    <Version>12.8.0</Version>
    <Description>.NET bindings for the Nuke Swift image loading library</Description>
    <PackageTags>swift;dotnet;interop;nuke;image-loading;ios</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Package the README -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
